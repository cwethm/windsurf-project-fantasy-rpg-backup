{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voxel-mmo.local/schemas/building_schematic.schema.json",
  "title": "Building Schematic",
  "type": "object",
  "required": ["id", "origin", "blocks"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "enum": ["building", "site", "decor", "room"] },
    "site_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "size": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "integer", "minimum": 1 }
    },
    "origin": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "integer" }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x", "y", "z", "id"],
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "z": { "type": "integer" },
          "id": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
