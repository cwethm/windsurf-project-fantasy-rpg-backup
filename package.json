{
  "name": "voxel-mmo",
  "version": "1.0.0",
  "description": "3D Voxel MMO Server/Client Application",
  "main": "server.py",
  "scripts": {
    "server": "python3 server.py",
    "client": "cd client && python3 -m http.server 8080",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-deps": "pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["voxel", "mmo", "3d", "multiplayer", "game"],
  "author": "",
  "license": "MIT"
}
